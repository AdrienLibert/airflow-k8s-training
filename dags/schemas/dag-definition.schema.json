{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "dag-definition.schema.json",
  "type": "object",
  "minProperties": 1,
  "maxProperties": 1,
  "additionalProperties": false,
  "patternProperties": {
    "^[a-z][a-z0-9_]*$": {
      "$ref": "#/$defs/dag"
    }
  },
  "$defs": {
    "dag": {
      "type": "object",
      "required": ["schedule", "start_date", "tasks"],
      "additionalProperties": false,
      "properties": {
        "schedule": {
          "type": "string",
          "minLength": 1
        },
        "start_date": {
          "type": "string",
          "format": "date"
        },
        "catchup": {
          "type": "boolean"
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        },
        "tasks": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/task"
          }
        }
      }
    },
    "task": {
      "type": "object",
      "required": ["task_id", "module"],
      "additionalProperties": false,
      "properties": {
        "task_id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_]*$"
        },
        "module": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_]*$"
        },
        "dependencies": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9_]*$"
          },
          "uniqueItems": true
        }
      }
    }
  }
}
